__pycache__/
*.py[cod]
.env
.venv/
.ipynb_checkpoints/
.DS_Store
*.log

# Pipeline outputs (regenerated by running scripts 01-10)
data/raw/
data/processed/*.csv
data/processed/*.parquet
output/*.csv
output/*.json
output/*.png
output/figures/*.png
output/figures/*.pdf

# Audit intermediates (regenerated by audit/run.sh)
audit/_extracted_numbers.json
audit/_diff.json
audit/_regenerated_table1.tex

# LaTeX build artefacts (regenerated by `make`)
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!output/.gitkeep
!output/figures/.gitkeep

# Keep the fund metadata
!data/fund_metadata.csv
