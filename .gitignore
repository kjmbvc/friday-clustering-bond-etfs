# LaTeX build artefacts (paper/ Makefile output)
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc

# Make-tracked done files
code/*.done

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!output/.gitkeep
!output/figures/.gitkeep

# Keep the fund metadata (only pre-canned data)
!data/fund_metadata.csv

